# Copy to `.env` and fill in values. Never commit `.env`.

# PostgreSQL connection (Railway, Supabase, Neon, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth / Auth.js — required in production (`openssl rand -base64 32`)
AUTH_SECRET="generate-a-long-random-string"

# One-time admin bootstrap for `npm run db:seed` (also used to set password on re-seed)
ADMIN_EMAIL="admin@yourcommunity.org"
ADMIN_PASSWORD="choose-a-strong-password"

# Public site copy (safe to expose to the browser)
NEXT_PUBLIC_COMMUNITY_NAME="Prayaas"
NEXT_PUBLIC_UPI_ID="your-collective@upi"
NEXT_PUBLIC_REGISTRATION_FEE_INR="501"
# Path or URL to your static UPI QR image (replace `public/upi-qr.svg` or set a CDN URL)
NEXT_PUBLIC_UPI_QR_IMAGE="/upi-qr.svg"
