generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id                   String   @id @default(uuid())
  submissionCode       String   @unique @map("submission_code")
  fullName             String   @map("full_name")
  gender               String
  age                  Int
  mobileNumber         String   @map("mobile_number")
  biodataFileKey       String   @map("biodata_file_key")
  paymentScreenshotKey String   @map("payment_screenshot_key")
  paymentStatus        String   @default("Pending") @map("payment_status")
  createdAt            DateTime @default(now()) @map("created_at")

  @@index([mobileNumber])
  @@index([fullName])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("submissions")
}

model SiteSettings {
  id                 Int      @id
  paymentQrFileKey   String?  @map("payment_qr_file_key")
  whatsappQrFileKey  String?  @map("whatsapp_qr_file_key")
  upiId              String?
  registrationFeeInr Int?     @map("registration_fee_inr")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("admin_users")
}

